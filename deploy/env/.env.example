# Template for container-mode env vars. Copy to deploy/env/.env (gitignored) and fill in.
IS_DOCKER=true
HTTP_ADDR=:8080

# PostgreSQL
POSTGRES_DSN=postgres://app:app@postgres:5432/app?sslmode=disable

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=app

# Media service object storage (minio-go client config)
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=clips
STORAGE_USE_SSL=false

# Cross-service S2S base URLs (compose DNS, container port :8080)
RATINGS_BASE_URL=http://ratings:8080
REPORTS_BASE_URL=http://reports:8080
STORE_BASE_URL=http://store:8080
MEDIA_BASE_URL=http://media:8080

# Google OAuth (per service)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=

# Stripe (per service)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
