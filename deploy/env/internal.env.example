# Internal service-to-service auth (issues #142-#145).
# ONE strong random value shared by store, ratings, koth, media.
# Generate the real file (never committed):
#   cp deploy/env/internal.env.example deploy/env/internal.env
#   sed -i "s/^INTERNAL_API_TOKEN=.*/INTERNAL_API_TOKEN=$(openssl rand -hex 32)/" deploy/env/internal.env
# Services fail CLOSED (503 on internal routes) when this is empty — by design.
INTERNAL_API_TOKEN=change-me
