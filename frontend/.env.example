# With all four vars left empty (the default below) the app talks same-origin
# and relies on the Vite dev-server proxy (see vite.config.ts's server.proxy)
# to route /v1/* HTTP calls and /ws/match, /ws/signal WS connections to their
# backend services on localhost. A deployed / non-proxied frontend (e.g. built
# and served standalone) MUST set VITE_API_URL and VITE_WS_URL to the real
# backend origin(s) instead.

# Base URL for HTTP API calls. Empty = same-origin (dev-server proxy).
# Set to an absolute base URL (e.g. https://api.example.com) for a deployed
# or non-proxied frontend.
VITE_API_URL=

# Base URL for WebSocket connections (matchmaking search, battle/invite
# signaling). Empty = same-origin (dev-server proxy). Set to an absolute
# origin (e.g. wss://api.example.com) for a deployed frontend.
VITE_WS_URL=

# Google OAuth client id. Used by Login.tsx to build the Google auth URL;
# left empty the client_id query param is simply empty.
VITE_GOOGLE_CLIENT_ID=

# Google OAuth redirect URI registered for the client above.
VITE_GOOGLE_REDIRECT_URI=
