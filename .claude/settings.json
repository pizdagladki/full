      "Bash(gh secret:*)",
      "Bash(gh auth token:*)",
      "mcp__github__merge_pull_request",
      "mcp__github__delete_file",
      "mcp__github__push_files",
      "mcp__github__create_or_update_file",
      "Edit(.github/**)",
      "Write(.github/**)",
      "Read(**/.env)",
      "Read(**/config.yaml)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/gofmt.mjs"], "timeout": 30 }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/trace.mjs"], "timeout": 10 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/spellcheck.mjs"], "timeout": 15 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "node", "args": ["${CLAUDE_PROJECT_DIR}/.claude/hooks/block-github.mjs"], "timeout": 10 }
        ]
      }
    ]
  }
}
